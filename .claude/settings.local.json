{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"includeCoAuthoredBy": false,
	"permissions": {
		"allow": [
			"mcp__rust-mcp",
			"mcp__cargo-mcp",
			"mcp__context7",
			"mcp__serena",
			"mcp__cargo-mcp__cargo_check",
			"mcp__cargo-mcp__cargo_test",
			"mcp__cargo-mcp__cargo_clippy",
			"Bash(git:*)",
			"Bash(cargo:*)",
			"Bash(./target/debug/rssh-agent:*)",
			"Bash(./target/release/rssh-agent:*)",
			"Bash(./target/**/rssh-agent:*)",
			"Bash(./target/:*)",
			"Bash(./:*)",
			"Bash(head:*)",
			"Bash(chmod:*)",
			"Bash(rustc:*)",
			"WebSearch"
		],
		"deny": ["Bash(sudo:*)"]
	},
	"enableAllProjectMcpServers": true,
	"enabledMcpjsonServers": ["rust-mcp"]
}
