[Unit]
Description=rssh-agent SSH authentication agent
Documentation=man:rssh-agent(1)
Requires=rssh-agent.socket
After=graphical-session.target

[Service]
Type=simple
Environment=SSH_AUTH_SOCK=%t/rssh-agent.socket
ExecStart=/usr/bin/rssh-agent daemon --foreground --dir=%h/.ssh/rssh-agent
ExecReload=/bin/kill -HUP $MAINPID
ExecStop=/usr/bin/systemctl --user unset-environment SSH_AUTH_SOCK
Restart=on-failure
RestartSec=5
TimeoutStopSec=30

# # Security settings
# NoNewPrivileges=true
